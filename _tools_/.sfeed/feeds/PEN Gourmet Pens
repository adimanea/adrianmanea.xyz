flickr.com/1979/45433114141_d7c873f4c3_z.jpg" width="640" /></a><script async="" charset="utf-8" src="//embedr.flickr.com/assets/client-code.js"></script></div><div style="text-align: center;"><a data-flickr-embed="true" href="https://www.flickr.com/gp/63862643@N02/5109ZS" nbsp="" title="Montblanc Heritage Spider Web Grey Ink 13"><img alt="Montblanc Heritage Spider Web Grey Ink 13" height="640" src="https://farm2.staticflickr.com/1925/43615785080_0f7afdd716_z.jpg" width="480" /></a><script async="" charset="utf-8" src="//embedr.flickr.com/assets/client-code.js"></script></div><div style="text-align: center;"><a data-flickr-embed="true" href="https://www.flickr.com/gp/63862643@N02/p1E3Rz" nbsp="" title="Montblanc Heritage Spider Web Grey Ink 11"><img alt="Montblanc Heritage Spider Web Grey Ink 11" height="368" src="https://farm2.staticflickr.com/1902/43615785220_4c0bb0ba11_z.jpg" width="640" /></a><script async="" charset="utf-8" src="//embedr.flickr.com/assets/client-code.js"></script></div><div style="text-align: center;"><a data-flickr-embed="true" href="https://www.flickr.com/gp/63862643@N02/24sS3g" nbsp="" title="Montblanc Heritage Spider Web Grey Ink 12"><img alt="Montblanc Heritage Spider Web Grey Ink 12" height="358" src="https://farm2.staticflickr.com/1945/45381445072_346fee8e51_z.jpg" width="640" /></a><script async="" charset="utf-8" src="//embedr.flickr.com/assets/client-code.js"></script></div><b>PROS</b><br /><ul><li>Nice color, very legible, even with finer writers.</li><li>Pretty bottle!</li><li>The bottle is easy to fill from.</li><li>Easy to store/stack on your shelf.</li><li>Shades beautifully.</li><li>A larger bottle of ink is nice - more ink than the little Special Edition bottles!</li><li>Great design on the box.</li><li>Water resistant.</li></ul><div style="text-align: center;"><b><a data-flickr-embed="true" href="https://www.flickr.com/gp/63862643@N02/a747AW" nbsp="" title="Montblanc Heritage Spider Web Grey Ink 5"><img alt="Montblanc Heritage